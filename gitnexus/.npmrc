# Enforce Node 20 (see package.json engines). Node 24 is unsupported (native addon / ABI issues).
engine-strict=true
# tree-sitter-fortran from GitHub declares peer tree-sitter@0.26; we keep tree-sitter@^0.21 per design.
# Allow install so the Fortran grammar can be used; runtime compatibility is best-effort.
legacy-peer-deps=true
